    if (menuIcon) menuIcon.style.display = 'none';
    if (closeIcon) closeIcon.style.display = 'inline';
    document.body.style.overflow = 'hidden'; // Prevent background scrolling
  } else {
    if (menuIcon) menuIcon.style.display = 'inline';
    if (closeIcon) closeIcon.style.display = 'none';
    document.body.style.overflow = ''; // Restore scrolling
  }
}

function toggleDropdown(event) {
  event.stopPropagation(); // Stop event from bubbling up
  
  // Find the button that was clicked
  let btn = event.target;
  while (btn && !btn.classList.contains('dropbtn')) {
    btn = btn.parentElement;
  }
  
  if (!btn) return;
  
  // Find the dropdown content
  const dropdown = btn.nextElementSibling;
  if (!dropdown) return;
  
  // Check if we're on mobile
  const isMobile = window.innerWidth <= 768;
  
  if (isMobile) {
    // On mobile: toggle with .show class
    dropdown.classList.toggle('show');
    
    // Close other dropdowns
    document.querySelectorAll('.dropdown-content').forEach(d => {
      if (d !== dropdown) d.classList.remove('show');
    });
  } else {
    // On desktop: let hover handle it, but we can still toggle for touch
    dropdown.classList.toggle('show');
  }
}

// Close mobile menu when clicking outside
document.addEventListener('click', function(event) {
  const nav = document.querySelector('nav');
  const navLinks = document.querySelector('.nav-links');
  const menuIcon = document.querySelector('.menu-icon');
  const closeIcon = document.querySelector('.close-icon');
  const toggle = document.querySelector('.mobile-menu-toggle');
  
  // Don't close if clicking on dropdown button or content
  if (event.target.closest('.dropbtn') || event.target.closest('.dropdown-content')) {
    return;
  }
  
  // Close mobile menu if clicking outside nav and menu is open
  if (navLinks && navLinks.classList.contains('active') && 
      !nav.contains(event.target) && 
      !toggle.contains(event.target)) {
    navLinks.classList.remove('active');
    if (menuIcon) menuIcon.style.display = 'inline';
    if (closeIcon) closeIcon.style.display = 'none';
    document.body.style.overflow = '';
  }
});

// Close dropdowns when clicking outside (desktop)
document.addEventListener('click', function(event) {
  // Don't close if clicking on dropdown button
  if (event.target.closest('.dropbtn')) {
    return;
  }
  
  // Don't close if clicking inside dropdown content
  if (event.target.closest('.dropdown-content')) {
    return;
  }
  
  // Close all dropdowns
  document.querySelectorAll('.dropdown-content').forEach(d => {
    d.classList.remove('show');
  });
});

// Unified ESC handler — nav, dropdowns, image modal, video modal
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    // Close video modal
    const videoModal = document.getElementById('videoModal');
    if (videoModal && videoModal.style.display === 'flex') {
      closeVideoModal();
      return;
    }
    // Close image modal
    const imageModal = document.getElementById('imageModal');
    if (imageModal && imageModal.classList.contains('active')) {
      closeImageModal();
      return;
    }
    // Close mobile nav
    const navLinks = document.querySelector('.nav-links');
    const menuIcon = document.querySelector('.menu-icon');
    const closeIcon = document.querySelector('.close-icon');
    if (navLinks && navLinks.classList.contains('active')) {
      navLinks.classList.remove('active');
      if (menuIcon) menuIcon.style.display = 'inline';
      if (closeIcon) closeIcon.style.display = 'none';
      document.body.style.overflow = '';
    }
    // Close dropdowns
    document.querySelectorAll('.dropdown-content').forEach(d => {
      d.classList.remove('show');
    });
  }
});

// Handle window resize - reset mobile menu state
window.addEventListener('resize', function() {
  if (window.innerWidth > 768) {
    const navLinks = document.querySelector('.nav-links');
    const menuIcon = document.querySelector('.menu-icon');
    const closeIcon = document.querySelector('.close-icon');
    
    if (navLinks && navLinks.classList.contains('active')) {
      navLinks.classList.remove('active');
      if (menuIcon) menuIcon.style.display = 'inline';
      if (closeIcon) closeIcon.style.display = 'none';
      document.body.style.overflow = '';
    }
    
    // Close all dropdowns
    document.querySelectorAll('.dropdown-content').forEach(d => {
      d.classList.remove('show');
    });
  }
});

// Initialize active state for current page
document.addEventListener('DOMContentLoaded', function() {
  const currentPage = window.location.pathname.split('/').pop() || 'index.html';
  
  document.querySelectorAll('.nav-links a').forEach(link => {
    if (link.getAttribute('href') === currentPage) {
      link.style.background = 'rgba(76,175,80,0.25)';
      link.style.color = '#fff';
    }
  });
  
  // Set aria attributes for accessibility
  document.querySelectorAll('.dropbtn').forEach(btn => {
    btn.setAttribute('aria-haspopup', 'true');
    btn.setAttribute('aria-expanded', 'false');
  });
});

// Image Modal Functionality
function closeImageModal() {
  const modal = document.getElementById('imageModal');
  if (modal) modal.classList.remove('active');
}

// Initialize image modal
if (document.readyState === 'loading') {
  document.addEventListener('DOMContentLoaded', initImageModal);
} else {
  initImageModal();
}

function initImageModal() {
  const modal = document.getElementById('imageModal');
  const modalImg = document.getElementById('modalImage');
  
  if (!modal || !modalImg) return;
  
  const images = document.querySelectorAll('img:not(.mobile-menu-toggle):not(.mobile-menu-toggle *)');
  
  images.forEach(function(img) {
    if (img.parentElement && img.parentElement.tagName !== 'BUTTON') {
      img.style.cursor = 'pointer';
      img.addEventListener('click', function() {
        modal.classList.add('active');
        modalImg.src = this.src;
        modalImg.alt = this.alt || '';
      });
    }
  });
  
  const closeBtn = modal.querySelector('.close-modal');
  if (closeBtn) {
    closeBtn.addEventListener('click', closeImageModal);
  }
  
  modal.addEventListener('click', function(e) {
    if (e.target === modal) {
      closeImageModal();
    }
  });
}
</script>

<!-- Image Modal -->
<div id="imageModal" class="image-modal">
 <span class="close-modal" onclick="closeImageModal()">&times;</span>
 <img loading="lazy" class="modal-content" id="modalImage" alt="">
</div>

<!-- Video Modal -->
<div id="videoModal" style="display:none; position:fixed; z-index:30000; left:0; top:0; width:100%; height:100%; background:rgba(0,0,0,0.92); align-items:center; justify-content:center; flex-direction:column;">
  <div style="position:relative; width:90%; max-width:760px;">
    <button onclick="closeVideoModal()" style="position:absolute; top:-44px; right:0; background:none; border:none; color:#fff; font-size:2.2rem; cursor:pointer; line-height:1;">✕</button>
    <div style="position:relative; padding-bottom:56.25%; height:0; overflow:hidden; border-radius:8px; box-shadow:0 8px 40px rgba(0,0,0,0.6);">
      <iframe id="videoModalFrame"
        src=""
        data-src="https://www.youtube.com/embed/2j-dF3hgdeE?autoplay=1&rel=0"
        title="PHIERS — The Math Congress Doesn't Want You to See (1:11)"
        frameborder="0"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
        style="position:absolute; top:0; left:0; width:100%; height:100%;">
      </iframe>
    </div>
    <p style="text-align:center; color:#81c784; margin-top:14px; font-size:1rem; font-weight:600;">1 minute 11 seconds. This is why they're terrified.</p>
    <div style="text-align:center; margin-top:12px;">
      <a href="https://www.change.org/p/put-the-600-telehealth-plan-on-the-aca-exchange-now" target="_blank"
        style="display:inline-block; background:#4caf50; color:#fff; padding:12px 30px; border-radius:6px; font-weight:700; text-decoration:none; font-size:1rem; margin-right:10px;">
        Sign the Petition →
      </a>
      <button onclick="closeVideoModal()" style="display:inline-block; background:transparent; color:#81c784; border:2px solid #4caf50; padding:12px 24px; border-radius:6px; font-weight:600; cursor:pointer; font-size:1rem;">
        Close
      </button>
    </div>
  </div>
</div>

<script>
function openVideoModal() {
  const modal = document.getElementById('videoModal');
  const frame = document.getElementById('videoModalFrame');
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
  // Load src only on open to prevent autoplay before user clicks
  if (!frame.src || frame.src === window.location.href) {
    frame.src = frame.getAttribute('data-src');
  }
}

function closeVideoModal() {
  const modal = document.getElementById('videoModal');
  const frame = document.getElementById('videoModalFrame');
  modal.style.display = 'none';
  document.body.style.overflow = '';
  // Stop video by clearing src
  frame.src = '';
}

// Close on backdrop click
document.getElementById('videoModal').addEventListener('click', function(e) {
  if (e.target === this) closeVideoModal();
});
</script>

<div style="text-align:center; padding: 10px; font-size: 0.8rem; color: #666;">PHIERS Movement — Organized. Mathematical. Unstoppable.</div>
</body>
</html>
